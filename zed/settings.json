{
  "cli_default_open_behavior": "existing_window",
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light Soft",
    "dark": "August - Gruvbox"
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Flow Dim Light",
    "dark": "Flow Deep"
  },
  "ui_font_family": "JetBrains Mono",
  "ui_font_size": 24,
  "ui_font_weight": 600,
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 20,
  "buffer_font_weight": 600,
  "current_line_highlight": "none",
  "cursor_shape": "block",
  "cursor_blink": true,
  "colorize_brackets": false,
  "rounded_selection": false,
  "selection_highlight": false,
  "minimap": {
    "show": "never"
  },
  "scrollbar": {
    "axes": {
      "vertical": true
    }
  },
  "indent_guides": {
    "enabled": false
  },
  "gutter": {
    "breakpoints": false,
    "folds": false,
    "runnables": false,
    "min_line_number_digits": null,
    "bookmarks": false,
    "line_numbers": false
  },
  "tab_size": 2,
  "soft_wrap": "editor_width",
  "show_wrap_guides": false,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "format_on_save": "off",
  "diff_view_style": "unified",
  "title_bar": {
    "show_sign_in": false,
    "show_user_menu": false,
    "show_user_picture": false,
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_branch_status_icon": false,
    "show_menus": false,
    "show_branch_name": false
  },
  "status_bar": {
    "cursor_position_button": true,
    "experimental.show": false,
    "line_endings_button": false,
    "active_encoding_button": "disabled",
    "active_language_button": false
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "agent_review": false,
    "selections_menu": false
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false
  },
  "tabs": {
    "show_close_button": "hidden",
    "git_status": false,
    "file_icons": false
  },
  "preview_tabs": {
    "enabled": false
  },
  "project_panel": {
    "dock": "left",
    "button": false,
    "default_width": 360.0,
    "sort_mode": "directories_first",
    "hide_root": true,
    "entry_spacing": "standard",
    "auto_fold_dirs": false,
    "sticky_scroll": false,
    "indent_size": 8.0,
    "indent_guides": {
      "show": "never"
    }
  },
  "outline_panel": {
    "button": false
  },
  "git_panel": {
    "button": false
  },
  "search": {
    "button": false
  },
  "diagnostics": {
    "button": false
  },
  "debugger": {
    "button": false
  },
  "collaboration_panel": {
    "button": false
  },
  "agent": {
    "button": false,
  },
  "terminal": {
    "button": false,
    "blinking": "on",
    "cursor_shape": "bar",
    "font_family": "JetBrains Mono",
    "font_size": 18,
    "font_weight": 600
  },
  "edit_predictions": {
    "provider": "zed"
  },
  "show_edit_predictions": true,
  "auto_signature_help": false,
  "inline_code_actions": false,
  "completions": {
    "lsp_insert_mode": "replace"
  },
  "git": {
    "blame": {
      "show_avatar": false
    },
    "inline_blame": {
      "enabled": false
    }
  },
  "file_scan_exclusions": [
    ".tanstack",
    "node_modules",
    "routeTree.gen.ts",
    "dist",
    ".git",
    "bun.lock",
    "pnpm-lock.yaml"
  ],
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "close_on_file_delete": true,
  "confirm_quit": false,
  "when_closing_with_no_tabs": "keep_window_open",
}
